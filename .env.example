# =============================================================
# DataPulse — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# =============================================================

# -----------------------------------------------------------
# Operational Database
# -----------------------------------------------------------
POSTGRES_DB=datapulse
POSTGRES_USER=datapulse
POSTGRES_PASSWORD=datapulse
DATABASE_URL=postgresql://datapulse:datapulse@db:5432/datapulse

# -----------------------------------------------------------
# Analytics Database (ETL + Streamlit)
# -----------------------------------------------------------
ANALYTICS_DB=datapulse_analytics
ANALYTICS_USER=analytics
ANALYTICS_PASSWORD=analytics
TARGET_DB_URL=postgresql://analytics:analytics@db-analytics:5432/datapulse_analytics

# -----------------------------------------------------------
# Django
# -----------------------------------------------------------
SECRET_KEY=change-me-in-production
DJANGO_SETTINGS_MODULE=datapulse.settings.dev
DEBUG=True

# -----------------------------------------------------------
# Email (backend — alerts, notifications; required for real delivery)
# Default: console backend (emails in logs). For real email (e.g. Gmail):
# Set EMAIL_BACKEND to smtp, then EMAIL_HOST_USER + EMAIL_HOST_PASSWORD (App Password).
# -----------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@datapulse.com
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Gmail example (use App Password, not account password):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=your-email@gmail.com

# -----------------------------------------------------------
# Gunicorn
# -----------------------------------------------------------
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_LOG_LEVEL=info

# -----------------------------------------------------------
# Grafana
# -----------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=datapulse123

# -----------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------
# API base URL used by the browser; use host-visible URL when frontend runs in Docker
NEXT_PUBLIC_API_URL=http://localhost:8000
