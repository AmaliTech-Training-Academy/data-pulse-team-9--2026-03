# --- Django General ---
SECRET_KEY=change-me-in-production
# DJANGO_SETTINGS_MODULE=datapulse.settings.dev

# --- Database ---
# For Docker: postgresql://datapulse:datapulse@db:5432/datapulse
# For Local Postgres: postgresql://<user>:<password>@localhost:5432/<dbname>
DATABASE_URL=postgresql://datapulse:datapulse@localhost:5432/datapulse

# --- Redis (Celery) ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=datapulse@amalitech.com
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Email Configuration (Gmail SMTP)
# -----------------------------------------------------------
# To use real email in development, set EMAIL_BACKEND to SMTP and provide credentials
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password  # Use an App Password, not your real password
DEFAULT_FROM_EMAIL=your-email@gmail.com
