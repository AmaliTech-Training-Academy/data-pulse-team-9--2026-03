# Terraform Variables for DataPulse Dev Environment
# Copy this to terraform.tfvars and fill in your actual values
# DO NOT commit terraform.tfvars to git - it contains sensitive data

# Network Configuration
allowed_cidr = "0.0.0.0/0"  # CHANGE THIS: Your IP/VPN CIDR (e.g., "203.0.113.0/24")

# GitHub Configuration
github_repo = "your-org/DatapulseMain"  # CHANGE THIS: Your GitHub repo in ORG/REPO format

# SSH Key for EC2 Access
public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQ..."  # CHANGE THIS: Your SSH public key content

# Database Credentials
postgres_user     = "datapulse_user"
postgres_password = "your-secure-password-123"  # pragma: allowlist secret
postgres_db       = "datapulse_db"

# Analytics Database Credentials
analytics_user     = "analytics_user"
analytics_password = "your-analytics-password-456"  # pragma: allowlist secret
analytics_db       = "analytics_db"

# Application Secret Key
secret_key = "your-django-secret-key-here-make-it-long-and-random"  # pragma: allowlist secret

# Grafana Credentials
grafana_user     = "admin"
grafana_password = "your-grafana-password-789"  # pragma: allowlist secret
